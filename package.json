{
  "name": "devicer.js",
  "version": "1.3.8",
  "type": "module",
  "description": "Open-Source Digital Fingerprinting Middleware",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "npx vitest run",
    "test:watch": "npx vitest watch",
    "test:coverage": "npx vitest run --coverage",
    "build": "tsc --outDir dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gatewaycorporate/fp-devicer.git"
  },
  "keywords": [
    "fingerprinting",
    "middleware",
    "identification",
    "tracking"
  ],
  "author": "Samuel Roux, Steven Perso, and one anonymous co-author",
  "license": "SEE LICENSE IN license.txt",
  "bugs": {
    "url": "https://github.com/gatewaycorporate/fp-devicer/issues"
  },
  "homepage": "https://github.com/gatewaycorporate/fp-devicer#readme",
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "tlsh": "^1.0.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^18.15.11",
    "@vitest/ui": "^3.2.4",
    "drizzle-kit": "^0.31.9",
    "happy-dom": "^20.8.3",
    "typescript": "^5.0.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "express": "^4.22.1",
    "ioredis": "^5.10.0"
  }
}
